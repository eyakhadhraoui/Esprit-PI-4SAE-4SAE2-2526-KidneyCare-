# ============================================================================
# KidneyCare Platform - Environment Configuration
# ============================================================================
# Copy this file to .env.local for local development overrides
# or set these as environment variables in your CI/CD pipeline

# ─── ENVIRONMENT MODE ───────────────────────────────────────────────────────
# Options: development, staging, production
ENVIRONMENT=development

# ─── DATABASE CONFIGURATION ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=prescription-Service

# ─── KEYCLOAK CONFIGURATION ─────────────────────────────────────────────────
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

# ─── OAUTH2 / JWT CONFIGURATION ─────────────────────────────────────────────
# Issuer URI for JWT validation (used by all services)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://keycloak:8080/realms/kidneyCare-realm
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://keycloak:8080/realms/kidneyCare-realm/protocol/openid-connect/certs
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080

# ─── FRONTEND CONFIGURATION ─────────────────────────────────────────────────
# API Gateway host for frontend (used in nginx reverse proxy)
GATEWAY_HOST=gateway:8095
KEYCLOAK_HOST=keycloak:8080

# ─── MAIL SERVICE CONFIGURATION (NEPHRO Service) ─────────────────────────────
# Configure email settings for sending notifications
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ─── EUREKA SERVICE DISCOVERY ────────────────────────────────────────────────
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:8761/eureka/

# ─── SPRING BOOT CONFIGURATION ──────────────────────────────────────────────
# Common Spring Boot settings
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# ─── DEBUG / LOGGING ────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARN, ERROR
LOGGING_LEVEL=INFO
